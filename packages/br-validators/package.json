{
  "name": "br-validators",
  "version": "0.7.0-alpha.0",
  "description": "100% open-source Brazilian document validators — CPF, CNPJ, CEP, and more",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cnpj": {
      "types": "./dist/cnpj.d.ts",
      "import": "./dist/cnpj.js"
    },
    "./cpf": {
      "types": "./dist/cpf.d.ts",
      "import": "./dist/cpf.js"
    },
    "./cep": {
      "types": "./dist/cep.d.ts",
      "import": "./dist/cep.js"
    },
    "./placa": {
      "types": "./dist/placa.d.ts",
      "import": "./dist/placa.js"
    },
    "./pis-pasep": {
      "types": "./dist/pis-pasep.d.ts",
      "import": "./dist/pis-pasep.js"
    },
    "./pix": {
      "types": "./dist/pix.d.ts",
      "import": "./dist/pix.js"
    },
    "./boleto": {
      "types": "./dist/boleto.d.ts",
      "import": "./dist/boleto.js"
    },
    "./cartao-credito": {
      "types": "./dist/cartao-credito.d.ts",
      "import": "./dist/cartao-credito.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
