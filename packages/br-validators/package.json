{
  "name": "@br-validators/core",
  "version": "0.11.0-alpha.0",
  "description": "100% open-source Brazilian document validators — CPF, CNPJ, CEP, IE (27 UFs), PIX, boleto, and more",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexandreZanata/br-validators.git",
    "directory": "packages/br-validators"
  },
  "homepage": "https://github.com/AlexandreZanata/br-validators/tree/main/packages/br-validators#readme",
  "bugs": {
    "url": "https://github.com/AlexandreZanata/br-validators/issues"
  },
  "keywords": [
    "brazil",
    "cpf",
    "cnpj",
    "cep",
    "validator",
    "inscricao-estadual",
    "pix",
    "boleto",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cnpj": {
      "types": "./dist/cnpj.d.ts",
      "import": "./dist/cnpj.js"
    },
    "./cpf": {
      "types": "./dist/cpf.d.ts",
      "import": "./dist/cpf.js"
    },
    "./cep": {
      "types": "./dist/cep.d.ts",
      "import": "./dist/cep.js"
    },
    "./telefone": {
      "types": "./dist/telefone.d.ts",
      "import": "./dist/telefone.js"
    },
    "./cnh": {
      "types": "./dist/cnh.d.ts",
      "import": "./dist/cnh.js"
    },
    "./renavam": {
      "types": "./dist/renavam.d.ts",
      "import": "./dist/renavam.js"
    },
    "./titulo-eleitor": {
      "types": "./dist/titulo-eleitor.d.ts",
      "import": "./dist/titulo-eleitor.js"
    },
    "./nfe-chave": {
      "types": "./dist/nfe-chave.d.ts",
      "import": "./dist/nfe-chave.js"
    },
    "./brcode": {
      "types": "./dist/brcode.d.ts",
      "import": "./dist/brcode.js"
    },
    "./placa": {
      "types": "./dist/placa.d.ts",
      "import": "./dist/placa.js"
    },
    "./pis-pasep": {
      "types": "./dist/pis-pasep.d.ts",
      "import": "./dist/pis-pasep.js"
    },
    "./pix": {
      "types": "./dist/pix.d.ts",
      "import": "./dist/pix.js"
    },
    "./boleto": {
      "types": "./dist/boleto.d.ts",
      "import": "./dist/boleto.js"
    },
    "./cartao-credito": {
      "types": "./dist/cartao-credito.d.ts",
      "import": "./dist/cartao-credito.js"
    },
    "./inscricao-estadual": {
      "types": "./dist/inscricao-estadual.d.ts",
      "import": "./dist/inscricao-estadual.js"
    },
    "./inscricao-estadual-produtor-rural": {
      "types": "./dist/inscricao-estadual-produtor-rural.d.ts",
      "import": "./dist/inscricao-estadual-produtor-rural.js"
    },
    "./detect": {
      "types": "./dist/detect.d.ts",
      "import": "./dist/detect.js"
    },
    "./sanitize": {
      "types": "./dist/sanitize.d.ts",
      "import": "./dist/sanitize.js"
    },
    "./generate": {
      "types": "./dist/generate.d.ts",
      "import": "./dist/generate.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
