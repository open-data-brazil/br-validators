{
  "name": "@br-validators/zod",
  "version": "1.8.3",
  "description": "Zod schemas for Brazilian document validators — delegates to @br-validators/core",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexandreZanata/br-validators.git",
    "directory": "packages/br-validators-zod"
  },
  "homepage": "https://github.com/AlexandreZanata/br-validators/tree/main/packages/br-validators-zod#readme",
  "bugs": {
    "url": "https://github.com/AlexandreZanata/br-validators/issues"
  },
  "keywords": [
    "brazil",
    "zod",
    "validator",
    "cpf",
    "cnpj",
    "cep"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cpf": {
      "types": "./dist/cpf.d.ts",
      "import": "./dist/cpf.js"
    },
    "./cnpj": {
      "types": "./dist/cnpj.d.ts",
      "import": "./dist/cnpj.js"
    },
    "./cep": {
      "types": "./dist/cep.d.ts",
      "import": "./dist/cep.js"
    },
    "./telefone": {
      "types": "./dist/telefone.d.ts",
      "import": "./dist/telefone.js"
    },
    "./placa": {
      "types": "./dist/placa.d.ts",
      "import": "./dist/placa.js"
    },
    "./pis-pasep": {
      "types": "./dist/pis-pasep.d.ts",
      "import": "./dist/pis-pasep.js"
    },
    "./pix": {
      "types": "./dist/pix.d.ts",
      "import": "./dist/pix.js"
    },
    "./boleto": {
      "types": "./dist/boleto.d.ts",
      "import": "./dist/boleto.js"
    },
    "./cartao-credito": {
      "types": "./dist/cartao-credito.d.ts",
      "import": "./dist/cartao-credito.js"
    },
    "./inscricao-estadual": {
      "types": "./dist/inscricao-estadual.d.ts",
      "import": "./dist/inscricao-estadual.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "node ../../scripts/assert-ci-publish.mjs && pnpm run build",
    "pretypecheck": "pnpm --filter @br-validators/core build",
    "pretest": "pnpm --filter @br-validators/core build",
    "pretest:coverage": "pnpm --filter @br-validators/core build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --max-warnings 0"
  },
  "peerDependencies": {
    "zod": "^3.23.0 || ^4.0.0"
  },
  "dependencies": {
    "@br-validators/core": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^3.24.4",
    "zod4": "npm:zod@^4.0.0"
  }
}
