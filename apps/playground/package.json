{
  "name": "@br-validators/playground",
  "version": "0.1.0-beta.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev --port 3000",
    "predev": "pnpm --filter @br-validators/cli build",
    "build": "next build",
    "prebuild": "pnpm --filter @br-validators/core build && pnpm --filter @br-validators/cli build",
    "start": "next start",
    "test": "vitest run",
    "pretest": "pnpm --filter @br-validators/cli build",
    "test:coverage": "vitest run --coverage",
    "pretest:coverage": "pnpm --filter @br-validators/cli build",
    "typecheck": "tsc --noEmit",
    "pretypecheck": "pnpm --filter @br-validators/core build && pnpm --filter @br-validators/cli build",
    "lint": "eslint app --max-warnings 0"
  },
  "dependencies": {
    "@br-validators/cli": "workspace:*",
    "@br-validators/core": "workspace:*",
    "next": "^15.3.3",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  }
}
